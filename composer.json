{
    "name": "caydeesoft/payments",
    "description": "Laravel mobile money payment gateway package for M-Pesa, Airtel Money, T-Kash, EazzyPay, MTN and Tigo callbacks, STK push, refunds, balances and disbursements.",
    "type": "library",
    "keywords": [
        "laravel payments",
        "mobile money",
        "mobile payments",
        "mpesa",
        "m-pesa",
        "safaricom daraja",
        "airtel money",
        "tkash",
        "t-kash",
        "eazzypay",
        "equity bank",
        "mtn mobile money",
        "tigo pesa",
        "stk push",
        "c2b",
        "b2c",
        "b2b",
        "payment callbacks",
        "kenya payments",
        "africa payments"
    ],
    "homepage": "https://github.com/caydeesoft/payments",
    "license": "MIT",
    "authors": [
        {
            "name": "Dennis Kiptugen",
            "email": "dennis.kiptoo@caydeesoft.com"
        }
    ],
    "require": {
        "php": "^7.4|^8.0|^8.1",
        "illuminate/routing": "^7|^8|^9",
        "illuminate/session": "^7|^8|^9",
        "illuminate/support": "^7|^8|^9"
    },
    "autoload": {
        "psr-4": {
            "Caydeesoft\\Payments\\": "src"
        }
    },
    "support": {
        "email": "dennis.kiptoo@caydeesoft.com",
        "issues": "https://github.com/caydeesoft/payments/issues",
        "source": "https://github.com/caydeesoft/payments"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Caydeesoft\\Payments\\PaymentsServiceProvider"
            ],

            "aliases": {
                "Payments": "Caydeesoft\\Payments\\Facade\\Payments"
            }
        }
    }

}
